MONGODB_URI=mongodb://mongodb:27017/?directConnection=true
MONGODB_DATABASE=charging_demo

# Examples:
# Local process on your machine: mongodb://localhost:27017/?directConnection=true
# Docker local demo (handled automatically by `make build`): mongodb://mongodb:27017/?replicaSet=rs0&directConnection=true
# Atlas: mongodb+srv://...

BACKEND_URL=http://localhost:4000
BACKEND_CORS_ORIGIN=http://localhost:3000
SIMULATOR_URL=http://localhost:8000

SESSION_TELEMETRY_INTERVAL_SECONDS=2
CHANGE_STREAM_RETRY_SECONDS=2
