{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch --watch-path src --watch-path schema src/server/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server/index.js",
    "codegen": "graphql-codegen --config codegen.js",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"No backend lint configured yet\""
  },
  "dependencies": {
    "@apollo/server": "^5.2.0",
    "@as-integrations/express5": "^1.1.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "graphql": "^16.11.0",
    "mongodb": "^7.1.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.0.1",
    "@graphql-codegen/typescript": "^5.0.5",
    "@graphql-codegen/typescript-resolvers": "^5.1.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/node": "^24.6.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
