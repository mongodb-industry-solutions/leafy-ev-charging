{
  "name": "s2dm-example-charging-session-app",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@11.8.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "set -a; [ -f ./.env ] && . ./.env; set +a; turbo run dev --parallel",
    "build": "turbo run build",
    "codegen": "npm run codegen -w backend && npm run codegen -w frontend",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck"
  },
  "overrides": {
    "uuid": "^14.0.0",
    "postcss": "^8.5.10",
    "next": {
      "postcss": "^8.5.10"
    }
  },
  "devDependencies": {
    "turbo": "^2.8.11"
  }
}
